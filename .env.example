# 应用配置
APP_NAME=OnCall
DEBUG=True
HOST=0.0.0.0
PORT=9900

# DashScope 配置（必填：https://dashscope.aliyun.com/ 申请 API Key）
DASHSCOPE_API_KEY=sk-your-api-key-here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG 配置
RAG_TOP_K=10
RAG_SCORE_THRESHOLD=0.5
RAG_MODEL=qwen-max

# Rerank 配置
RERANK_ENABLED=True
RERANK_MODEL=qwen3-rerank
RERANK_TOP_N=3

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# 上下文压缩配置
CONTEXT_COMPRESSION_ENABLED=True
CONTEXT_COMPRESSION_TRIGGER_FRACTION=0.7
CONTEXT_COMPRESSION_KEEP_RECENT=6
CONTEXT_COMPRESSION_MODEL_WINDOW=32768

# 会话持久化配置（SQLite）
CHECKPOINT_DB_PATH=data/oncall_sessions.db

# MCP 服务配置
# 支持的 transport 类型：stdio（本地进程）、streamable-http（HTTP 流）
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Prometheus 配置
PROMETHEUS_BASE_URL=http://localhost:9090
